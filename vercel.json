{
  "buildCommand": "cd EDITH/frontend && npm install && npm run build",
  "outputDirectory": "EDITH/frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-url.railway.app/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
